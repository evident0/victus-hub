#!/usr/bin/env bash
# UI-only test run — no kernel module prompts, no daemon installation.
# Uninstalls the daemon if present, then launches the Qt app standalone.
set -euo pipefail

ROOT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)

SERVICE_NAME=victus-hubd.service
SERVICE_DST="/etc/systemd/system/$SERVICE_NAME"
SOCKET_PATH="/run/victus-hubd/victus-hub.sock"
SOCKET_RUNTIME_DIR="/run/victus-hubd"

if [ "$(id -u)" -eq 0 ]; then
	SUDO=()
else
	SUDO=(sudo)
fi

# ── Uninstall daemon if present ──
printf '\033[1;34m── Uninstalling victus-hubd daemon (if present) ──\033[0m\n'

if command -v systemctl >/dev/null 2>&1; then
	if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
		printf 'Stopping %s...\n' "$SERVICE_NAME"
		"${SUDO[@]}" systemctl stop "$SERVICE_NAME" || true
	fi

	if systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null; then
		printf 'Disabling %s...\n' "$SERVICE_NAME"
		"${SUDO[@]}" systemctl disable "$SERVICE_NAME" || true
	fi

	if [ -f "$SERVICE_DST" ]; then
		printf 'Removing service file: %s\n' "$SERVICE_DST"
		"${SUDO[@]}" rm -f "$SERVICE_DST"
		"${SUDO[@]}" systemctl daemon-reload
		"${SUDO[@]}" systemctl reset-failed "$SERVICE_NAME" 2>/dev/null || true
	fi
fi

if [ -d "$SOCKET_RUNTIME_DIR" ]; then
	printf 'Removing runtime directory %s\n' "$SOCKET_RUNTIME_DIR"
	"${SUDO[@]}" rm -rf "$SOCKET_RUNTIME_DIR" || true
fi

printf '\033[32mDaemon uninstalled (or was not present)\033[0m\n'

# ── Editable pip install (app only, no daemon needed for UI test) ──
printf '\033[1;34m── Installing victus-hub (editable) ──\033[0m\n'
cd "$ROOT_DIR"
python3 -m pip install -e . --quiet 2>/dev/null || true

# ── Run Qt app ──
printf '\033[1;34m── Starting Victus Hub (UI-only) ──\033[0m\n'
cd "$ROOT_DIR"
exec env QT_QPA_PLATFORM=xcb python3 -m victus_hub

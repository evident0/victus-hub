#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
# shellcheck source=kmod-prompts.sh
source "$ROOT_DIR/scripts/kmod-prompts.sh"

SERVICE_NAME=hp-helperd.service
SOCKET_PATH=/run/hp-helperd/hp-helper-rs.sock
SERVICE_WAS_ACTIVE=0

if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then
	SERVICE_WAS_ACTIVE=1
fi

cleanup() {
	local status=$?

	# Restore fan to auto before quitting
	if [ -S "$SOCKET_PATH" ]; then
		python3 - "$SOCKET_PATH" <<'PY' || true
import socket, sys
path = sys.argv[1]
with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as sock:
    sock.settimeout(1.0)
    sock.connect(path)
    sock.sendall(b"fan-auto\n")
    sock.recv(256)
PY
	fi

	# Stop the service if we started it
	if [ "$SERVICE_WAS_ACTIVE" -eq 0 ] && command -v systemctl >/dev/null 2>&1; then
		sudo systemctl stop "$SERVICE_NAME" >/dev/null 2>&1 || true
	fi

	exit "$status"
}
trap cleanup EXIT INT TERM

cd "$ROOT_DIR"

# ── Optional: custom hp-wmi, RGB, MUX, ryzenadj ──
prompt_optional_components

# ── Reinstall daemon ──

printf '\033[1;34m── Installing hp-helperd daemon ──\033[0m\n'

# Editable pip install so hp_helperd is importable from anywhere
python3 -m pip install -e . --quiet 2>/dev/null || true

# Install systemd service (template uses @ROOT_DIR@; substitute real path)
SERVICE_SRC="$ROOT_DIR/data/hp-helperd.service"
SERVICE_DST="/etc/systemd/system/$SERVICE_NAME"

TMP_UNIT=$(mktemp)
sed "s|@ROOT_DIR@|$ROOT_DIR|g" "$SERVICE_SRC" > "$TMP_UNIT"

NEEDS_RELOAD=0
if [ ! -f "$SERVICE_DST" ] || ! cmp -s "$TMP_UNIT" "$SERVICE_DST"; then
	printf 'Installing systemd service to %s\n' "$SERVICE_DST"
	sudo install -Dm644 "$TMP_UNIT" "$SERVICE_DST"
	NEEDS_RELOAD=1
fi
rm -f "$TMP_UNIT"

if [ "$NEEDS_RELOAD" -eq 1 ]; then
	sudo systemctl daemon-reload
	sudo systemctl reset-failed "$SERVICE_NAME" >/dev/null 2>&1 || true
	sudo systemctl enable "$SERVICE_NAME" >/dev/null
fi

printf 'Starting %s...\n' "$SERVICE_NAME"
sudo systemctl restart "$SERVICE_NAME"

# Wait for socket to appear
for _ in $(seq 1 30); do
	if [ -S "$SOCKET_PATH" ]; then
		printf '\033[32mDaemon ready (%s)\033[0m\n' "$SOCKET_PATH"
		break
	fi
	sleep 0.2
done

# ── Run Qt app ──

printf '\033[1;34m── Starting HP Helper ──\033[0m\n'
cd "$ROOT_DIR"
exec env QT_QPA_PLATFORM=xcb python3 -m hp_helper
